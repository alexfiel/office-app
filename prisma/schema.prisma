// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String               @id @default(cuid())
  name               String
  email              String               @unique
  password           String
  designation        String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  role               Role                 @default(USER)
  
  // Relations
  notarialDocuments  NotarialDocument[]
  transferTaxes      TransferTax[]
  transferTaxDetails TransferTaxDetails[]
  realProperties     RealProperty[]
  chainTransactions  ChainTransaction[]
}

enum Role {
  USER
  ADMIN
}

model RealProperty {
  id                 String               @id @default(cuid())
  objid              String               @unique
  pin                String
  taxdecnumber       String
  owner              String
  rputype            String
  barangay           String
  classcode          String
  lotNumber          String?
  blockNumber        String?
  surveyno           String?
  tctOct             String?
  area               Float
  marketValue        Decimal
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  documentUrl        String?              // Added for your file upload

  // Relations
  userId             String
  user               User                 @relation(fields: [userId], references: [id])
  transferTaxDetails TransferTaxDetails[]
}

model NotarialDocument {
  id             String        @id @default(cuid())
  documentName   String
  documentType   String
  documentNumber String
  notarialDate   DateTime
  notarizedBy    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  document_url   String
  
  // Relations
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  // Added back-relation for TransferTax
  transferTaxes  TransferTax[] 
}

model TransferTax {
  id                 String               @id @default(cuid())
  transferee         String
  transferor         String
  transactionType   String
  considerationvalue Decimal
  totalmarketvalue   Decimal
  taxbase            Decimal
  taxdue             Decimal
  surcharge          Decimal
  interest           Decimal
  totalamountdue     Decimal
  paymentstatus      String
  transactionDate    DateTime             @default(now())
  dayselapsed        Int                  @default(0)
  createdAt          DateTime             @default(now())
  validuntil         String
  updatedAt          DateTime             @updatedAt

  // Relations
  notarialDocument   NotarialDocument     @relation(fields: [notarialDocumentId], references: [id])
  notarialDocumentId String
  userId             String
  user               User                 @relation(fields: [userId], references: [id])
  // Added back-relation for TransferTaxDetails
  details            TransferTaxDetails[] 
  chainTransactions  ChainTransaction[]
}

model TransferTaxDetails {
  id             String       @id @default(cuid())
  taxdecnumber   String
  lotNumber      String
  owner          String
  marketValue    Decimal
  area           Float
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  transferTax    TransferTax  @relation(fields: [transferTaxId], references: [id])
  transferTaxId  String
  realProperty   RealProperty @relation(fields: [realPropertyId], references: [id])
  realPropertyId String
  // Added the missing User relation field
  userId         String
  user           User         @relation(fields: [userId], references: [id])
}

model ChainTransaction {
  id             String       @id @default(cuid())
  transferee  String
  transferror String
  transactionType String
  lotnumber String
  area Float
  marketValue Decimal
  taxdue Decimal
  

  // Relations
  userId String
  user User @relation(fields: [userId], references: [id])
  transferTaxId String
  transferTax TransferTax @relation(fields: [transferTaxId], references: [id])

  
}

model OfficeSignature {
  id        String   @id @default(cuid())
  name      String
  designation String
  signatureUrl String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}