generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                    @id @default(cuid())
  name               String
  email              String                    @unique
  password           String
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  role               Role                      @default(USER)
  designation        String
  chainTransactions  ChainTransaction[]
  liquidations       LibrengSakayLiquidation[]
  trips              LibrengSakayTrip[]
  notarialDocuments  NotarialDocument[]
  realProperties     RealProperty[]
  transferTaxes      TransferTax[]
  transferTaxDetails TransferTaxDetails[]
}

model RealProperty {
  id                 String               @id @default(cuid())
  objid              String               @unique
  pin                String
  taxdecnumber       String
  owner              String
  rputype            String
  barangay           String
  classcode          String
  lotNumber          String?
  blockNumber        String?
  surveyno           String?
  tctOct             String?
  area               Float
  marketValue        Decimal
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  documentUrl        String?
  userId             String
  chainTransactions  ChainTransaction[]
  user               User                 @relation(fields: [userId], references: [id])
  transferTaxDetails TransferTaxDetails[]
}

model NotarialDocument {
  id             String        @id @default(cuid())
  documentName   String
  documentType   String
  documentNumber String
  notarialDate   DateTime
  notarizedBy    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  document_url   String
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  transferTaxes  TransferTax[]
}

model TransferTax {
  id                 String               @id @default(cuid())
  transferee         String
  transferor         String
  transactionType    String
  considerationvalue Decimal
  totalmarketvalue   Decimal
  taxbase            Decimal
  taxdue             Decimal
  surcharge          Decimal
  interest           Decimal
  totalamountdue     Decimal
  paymentstatus      String
  transactionDate    DateTime             @default(now())
  createdAt          DateTime             @default(now())
  validuntil         String
  updatedAt          DateTime             @updatedAt
  notarialDocumentId String
  userId             String
  dayselapsed        Int                  @default(0)
  chainTransactions  ChainTransaction[]
  notarialDocument   NotarialDocument     @relation(fields: [notarialDocumentId], references: [id])
  user               User                 @relation(fields: [userId], references: [id])
  details            TransferTaxDetails[]
}

model TransferTaxDetails {
  id             String       @id @default(cuid())
  taxdecnumber   String
  lotNumber      String
  owner          String
  marketValue    Decimal
  area           Float
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  transferTaxId  String
  realPropertyId String
  userId         String
  realProperty   RealProperty @relation(fields: [realPropertyId], references: [id])
  transferTax    TransferTax  @relation(fields: [transferTaxId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
}

model ChainTransaction {
  id             String        @id @default(cuid())
  userId         String
  transferTaxId  String
  basicTaxDue    Float
  createdAt      DateTime      @default(now())
  deceasedOwner  String
  deceasedShare  Float
  heirs          String
  taxBase        Float
  realPropertyId String?
  realProperty   RealProperty? @relation(fields: [realPropertyId], references: [id])
  transferTax    TransferTax   @relation(fields: [transferTaxId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model OfficeSignature {
  id           String   @id @default(cuid())
  name         String
  designation  String
  signatureUrl String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LibrengSakayRoute {
  id        String             @id @default(cuid())
  code      String
  routeName String
  fare      Float
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  trips     LibrengSakayTrip[]
}

model LibrengSakayTrip {
  id                 String                    @id @default(cuid())
  departureDate      DateTime
  driverName         String
  vehiclePlateNumber String
  numberofPax        Int
  fare               Float
  amount             Float
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  routeId            String
  userId             String
  liquidations       LibrengSakayLiquidation[]
  route              LibrengSakayRoute         @relation(fields: [routeId], references: [id])
  user               User                      @relation(fields: [userId], references: [id])
}

model LibrengSakayLiquidation {
  id                 String           @id @default(cuid())
  departureDate      DateTime
  paymentDate        DateTime
  arnumber           String
  driverName         String
  vehiclePlateNumber String
  numberofPax        Int
  fare               Float
  amount             Float
  preparedby         String
  approvedby         String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  tripId             String
  userId             String
  trip               LibrengSakayTrip @relation(fields: [tripId], references: [id])
  user               User             @relation(fields: [userId], references: [id])
}

model LibrengSakayBudget {
  id          String   @id @default(cuid())
  year        Int
  month       Int?
  totalBudget Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}
