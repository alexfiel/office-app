generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                             @id @default(cuid())
  name                    String
  email                   String                             @unique
  password                String
  createdAt               DateTime                           @default(now())
  updatedAt               DateTime                           @updatedAt
  role                    Role                               @default(USER)
  designation             String
  apiKeys                 ApiKeyModel[]
  chainTransactions       ChainTransaction[]
  foodVouchers            FoodVoucher[]
  foodVoucherAcks         FoodVoucherIssuerAcknowledgement[]
  foodVoucherClaims       FoodVoucherRedemptionClaim[]
  foodVoucherVendors      FoodVoucherVendor[]
  foodVoucherVendorClaims FoodVoucherVendorClaim[]
  liquidations            LibrengSakayLiquidation[]
  trips                   LibrengSakayTrip[]
  notarialDocuments       NotarialDocument[]
  realProperties          RealProperty[]
  transferTaxes           TransferTax[]
  transferTaxDetails      TransferTaxDetails[]
}

model RealProperty {
  id                 String               @id @default(cuid())
  objid              String               @unique
  pin                String
  taxdecnumber       String
  owner              String
  rputype            String
  barangay           String
  classcode          String
  lotNumber          String?
  blockNumber        String?
  surveyno           String?
  tctOct             String?
  area               Float
  marketValue        Decimal
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  documentUrl        String?
  userId             String
  chainTransactions  ChainTransaction[]
  user               User                 @relation(fields: [userId], references: [id])
  transferTaxDetails TransferTaxDetails[]
}

model NotarialDocument {
  id             String        @id @default(cuid())
  documentName   String
  documentType   String
  documentNumber String
  notarialDate   DateTime
  notarizedBy    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  document_url   String
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  transferTaxes  TransferTax[]
}

model TransferTax {
  id                 String               @id @default(cuid())
  transferee         String
  transferor         String
  transactionType    String
  considerationvalue Decimal
  totalmarketvalue   Decimal
  taxbase            Decimal
  taxdue             Decimal
  surcharge          Decimal
  interest           Decimal
  totalamountdue     Decimal
  paymentstatus      String
  transactionDate    DateTime             @default(now())
  createdAt          DateTime             @default(now())
  validuntil         String
  updatedAt          DateTime             @updatedAt
  notarialDocumentId String
  userId             String
  dayselapsed        Int                  @default(0)
  chainTransactions  ChainTransaction[]
  notarialDocument   NotarialDocument     @relation(fields: [notarialDocumentId], references: [id])
  user               User                 @relation(fields: [userId], references: [id])
  details            TransferTaxDetails[]
}

model TransferTaxDetails {
  id             String       @id @default(cuid())
  taxdecnumber   String
  lotNumber      String
  owner          String
  marketValue    Decimal
  area           Float
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  transferTaxId  String
  realPropertyId String
  userId         String
  realProperty   RealProperty @relation(fields: [realPropertyId], references: [id])
  transferTax    TransferTax  @relation(fields: [transferTaxId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
}

model ChainTransaction {
  id             String        @id @default(cuid())
  userId         String
  transferTaxId  String
  basicTaxDue    Float
  createdAt      DateTime      @default(now())
  deceasedOwner  String
  deceasedShare  Float
  heirs          String
  taxBase        Float
  realPropertyId String?
  realProperty   RealProperty? @relation(fields: [realPropertyId], references: [id])
  transferTax    TransferTax   @relation(fields: [transferTaxId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model OfficeSignature {
  id           String   @id @default(cuid())
  name         String
  designation  String
  signatureUrl String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LibrengSakayRoute {
  id        String             @id @default(cuid())
  code      String
  routeName String
  fare      Float
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  trips     LibrengSakayTrip[]
}

model LibrengSakayTrip {
  id                 String                    @id @default(cuid())
  departureDate      DateTime
  driverName         String
  vehiclePlateNumber String
  numberofPax        Int
  fare               Float
  amount             Float
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  routeId            String
  userId             String
  liquidations       LibrengSakayLiquidation[]
  route              LibrengSakayRoute         @relation(fields: [routeId], references: [id])
  user               User                      @relation(fields: [userId], references: [id])
}

model LibrengSakayLiquidation {
  id                 String           @id @default(cuid())
  departureDate      DateTime
  paymentDate        DateTime
  arnumber           String
  driverName         String
  vehiclePlateNumber String
  numberofPax        Int
  fare               Float
  amount             Float
  preparedby         String
  approvedby         String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  tripId             String
  userId             String
  trip               LibrengSakayTrip @relation(fields: [tripId], references: [id])
  user               User             @relation(fields: [userId], references: [id])
}

model LibrengSakayBudget {
  id          String   @id @default(cuid())
  year        Int
  month       Int?
  totalBudget Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FoodVoucher {
  id                String                              @id @default(cuid())
  voucherCode       String
  date              DateTime
  amount            Float
  createdAt         DateTime                            @default(now())
  updatedAt         DateTime                            @updatedAt
  userId            String
  vendorId          String?
  user              User                                @relation(fields: [userId], references: [id])
  vendor            FoodVoucherVendor?                  @relation(fields: [vendorId], references: [id])
  redemptionDetails FoodVoucherRedemptionClaimDetails[]
}

model FoodVoucherVendor {
  id               String                       @id @default(cuid())
  vendorName       String
  market           String
  stallNo          String
  userId           String
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  foodVouchers     FoodVoucher[]
  redemptionClaims FoodVoucherRedemptionClaim[]
  user             User                         @relation(fields: [userId], references: [id])
}

model FoodVoucherRedemptionClaim {
  id              String                              @id @default(cuid())
  redemptionCode  String                              @unique
  vendorId        String
  totalAmount     Float
  date            DateTime
  status          String                              @default("PENDING")
  createdAt       DateTime                            @default(now())
  updatedAt       DateTime                            @updatedAt
  userId          String
  acknowledgement FoodVoucherIssuerAcknowledgement?
  user            User                                @relation(fields: [userId], references: [id])
  vendor          FoodVoucherVendor                   @relation(fields: [vendorId], references: [id])
  details         FoodVoucherRedemptionClaimDetails[]
}

model FoodVoucherRedemptionClaimDetails {
  id                String                     @id @default(cuid())
  redemptionClaimId String
  foodVoucherId     String
  amount            Float
  foodVoucher       FoodVoucher                @relation(fields: [foodVoucherId], references: [id])
  redemptionClaim   FoodVoucherRedemptionClaim @relation(fields: [redemptionClaimId], references: [id])
}

model FoodVoucherIssuerAcknowledgement {
  id                String                      @id @default(cuid())
  date              DateTime                    @default(now())
  userId            String
  acknowledged      Boolean                     @default(false)
  ackDate           DateTime?
  ackBy             String?
  createdAt         DateTime                    @default(now())
  arNumber          String                      @unique
  redemptionClaimId String?                     @unique
  vendorClaimId     String?                     @unique
  redemptionClaim   FoodVoucherRedemptionClaim? @relation(fields: [redemptionClaimId], references: [id])
  user              User                        @relation(fields: [userId], references: [id])
  vendorClaim       FoodVoucherVendorClaim?     @relation(fields: [vendorClaimId], references: [id])
}

model FoodVoucherVendorClaim {
  id              String                            @id @default(cuid())
  market          String
  stallNo         String
  vendorName      String
  claimControlNo  String
  totalAmount     Float
  userId          String
  createdAt       DateTime                          @default(now())
  updatedAt       DateTime                          @updatedAt
  status          String                            @default("PENDING")
  verifiedVoucherCodes  String[]  @default([])
  acknowledgement FoodVoucherIssuerAcknowledgement?
  user            User                              @relation(fields: [userId], references: [id])
}

model ApiKeyModel {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

enum Role {
  USER
  ADMIN
  ISSUER
  LIQUIDATOR
  VALIDATOR
}
